{
  "name": "zig-dom",
  "version": "0.1.4",
  "description": "Zig-backed native DOM implementation with a built-in test runner",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:native": "bun run scripts/build-native.ts",
    "build:packages": "bun run scripts/build-native-packages.ts",
    "build": "bun run build:packages",
    "test": "zig build run -- test --dom tests/runner/*.test.* tests/integration",
    "test:dev": "bun run scripts/build-dev.ts",
    "test:perf": "bun run scripts/build-perf.ts",
    "test:wpt": "bun run scripts/run-wpt-native.ts --manifest wpt/manifest/upstream-dom.json --wpt-root .wpt-cache/web-platform-tests"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.15.21",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "bun-types": "^1.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^6.0.3"
  }
}
