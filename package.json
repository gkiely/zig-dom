{
  "name": "zig-dom",
  "version": "0.1.4",
  "description": "Zig-backed native DOM implementation with a built-in test runner",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:native": "bun run scripts/build-native.ts",
    "build:packages": "bun run scripts/build-native-packages.ts",
    "build": "bun run build:packages",
    "build:watch": "zig build -Doptimize=ReleaseFast --summary none --watch -fincremental",
    "test": "zig build run -Doptimize=Debug --summary none -- test --root ../youneedawiki",
    "test:branch:gate": "bun run test:perf ../youneedawiki/src/elements ../youneedawiki/src/components",
    "test:wpt": "bun run scripts/run-wpt-native.ts --manifest wpt/manifest/upstream-dom.json --wpt-root .wpt-cache/web-platform-tests",
    "test:wpt:slow": "bun run scripts/run-wpt-native.ts --manifest wpt/manifest/upstream-dom.json --wpt-root .wpt-cache/web-platform-tests --only-slow --timeout-ms 180000",
    "test:wpt:all": "bun run scripts/run-wpt-native.ts --manifest wpt/manifest/upstream-dom.json --wpt-root .wpt-cache/web-platform-tests --include-slow --timeout-ms 180000",
    "test:perf": "zig build -Doptimize=ReleaseFast --summary none && time zig-out/bin/zig-dom test --dom --root ../youneedawiki",
    "test:perf:debug": "ZIG_DOM_PROFILE_MODULES=1 ZIG_DOM_PROFILE=1 time zig-out/bin/zig-dom test --dom --root ../youneedawiki",    
    "test:perf:gate": "bun run scripts/test-perf-gate.ts",
    "sample": "bun run scripts/sample.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "bun-types": "^1.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^6.0.3"
  }
}
