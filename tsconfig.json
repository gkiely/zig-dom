{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2024",
      "DOM"
    ],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "types": [
      "bun-types",
      "node"
    ],
    "jsx": "react-jsx",
    "noEmit": true
  },
  "include": [
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "wpt/.native-generated",
    ".wpt-cache",
    ".zig-cache",
    ".zig-dom-cache",
    ".zig-global-cache",
    "zig-out"
  ]
}
